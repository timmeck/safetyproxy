# SafetyProxy Configuration

# LLM Provider: "anthropic" or "ollama"
LLM_PROVIDER=ollama

# Anthropic (if using Claude)
ANTHROPIC_API_KEY=

# OpenAI (if using OpenAI)
OPENAI_API_KEY=

# Ollama (local LLM)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# SafetyProxy settings
SAFETYPROXY_PORT=8700
SAFETYPROXY_MODEL=
SAFETYPROXY_API_KEY=

# Logging
LOG_LEVEL=INFO
